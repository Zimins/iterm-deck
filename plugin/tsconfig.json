{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "declaration": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": false,
    "types": ["node"],
    "outDir": "./dev.lightsoft.iterm-deck.sdPlugin/bin",
    "rootDir": "./src"
  },
  "include": ["src/**/*"]
}
